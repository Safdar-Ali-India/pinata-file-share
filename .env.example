# Pinata (server-side only — never expose to the browser)
PINATA_JWT=your_pinata_jwt_here
PINATA_GATEWAY=your-gateway.mypinata.cloud

# Database (local file or Turso/libSQL URL for production)
DATABASE_URL=file:./data/app.db

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron cleanup endpoint protection
CRON_SECRET=generate_a_long_random_string

# Optional: max upload size in bytes (default 52428800 = 50MB)
MAX_UPLOAD_BYTES=52428800
